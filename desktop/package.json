{
  "name": "tue-study-hub-desktop",
  "private": true,
  "version": "0.1.9",
  "description": "Electron desktop shell for TUE Study Hub.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron:build,electron:run \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 file:dist-electron/electron/main.js && nodemon --watch dist-electron --ext js --exec electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc --noEmit -p tsconfig.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:backend": "node scripts/build-python-sidecar.mjs",
    "package": "npm run build && electron-builder --config electron-builder.yml",
    "dist": "npm run build:backend && npm run package",
    "dist:mac:signed": "node scripts/dist-macos-signed-local.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "get-port": "^7.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.14",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.10",
    "typescript": "5.8.2",
    "vite": "^8.0.3",
    "wait-on": "^8.0.1"
  }
}
